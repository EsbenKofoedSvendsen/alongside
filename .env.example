# Copy to .env.local and fill in. Never commit real keys.

# AI provider for the Care Copilot (checked in this order):
# 1. DeepSeek (OpenAI-compatible)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
# 2. Anthropic Claude (used if no DeepSeek key is set)
# ANTHROPIC_API_KEY=
# With neither key set, the copilot runs its built-in deterministic guidance
# engine — every flow still works, answers are just not LLM-generated.

# Session signing secret — set a long random string in production.
SESSION_SECRET=
